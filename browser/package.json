{
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "npm run build && concurrently \"npm:watch\" \"npm:ext\"",
    "ext": "web-ext run --firefox=/Applications/Firefox.app/Contents/MacOS/firefox --firefox-profile=default-release --keep-profile-changes --source-dir=."
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^143.0.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.9.3",
    "web-ext": "^8.4.0"
  }
}
